# Configuration template — copy to .env and fill in your values
# DO NOT commit the .env file to git (it's in .gitignore)

# Pinned container images (override when you intentionally upgrade)
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
GRAFANA_IMAGE=grafana/grafana:11.1.5
CADDY_IMAGE=caddy:2.8.4
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.8.2
LOKI_IMAGE=grafana/loki:2.9.8
PROMTAIL_IMAGE=grafana/promtail:2.9.8

# Wazuh overlay versions and credentials
WAZUH_VERSION=4.8.2
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=change-this-indexer-password
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=change-this-api-password

# Grafana admin credentials (required)
# Generate a strong password, e.g.:
# openssl rand -base64 24
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-to-a-strong-password

# Pi-hole exporter API token
# Get from Pi-hole Settings → API → Show API Token
PIHOLE_API_TOKEN=your-api-token-here

# Caddy reverse proxy domains
# Use your actual domain or local hostname
# Examples: grafana.example.com, grafana.local, grafana.192.168.1.100.nip.io
GRAFANA_DOMAIN=grafana.example.com
PROMETHEUS_DOMAIN=prometheus.example.com

# Caddy email for Let's Encrypt (optional, used for cert notifications)
# Only needed if using Let's Encrypt for public domains
CADDY_ADMIN_EMAIL=admin@example.com
