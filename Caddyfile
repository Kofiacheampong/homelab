# HTTPS for Grafana (local domain with self-signed cert)
grafana.kofihomelab.duckdns.org {
    reverse_proxy grafana:3000
}

pihole.kofihomelab.duckdns.org {
    reverse_proxy 192.168.1.200:80
}

wazuh.kofihomelab.duckdns.org {
    reverse_proxy 192.168.1.200:5601
}

prometheus.kofihomelab.duckdns.org {
    reverse_proxy prometheus:9090
}